#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Create config dir if not present
if [[ ! -d "${PWD}/config" ]]; then
    mkdir -p "${PWD}/config"
    uv run hass --config "${PWD}/config" --script ensure_config
fi

# Prepend mock smbus2 so `import smbus2` resolves to the fake module
export PYTHONPATH="${PWD}/testing/mock_smbus2:${PWD}/custom_components${PYTHONPATH:+:$PYTHONPATH}"

# Create fake /dev/i2c-1 so config_flow's Path.exists() check passes
if [[ ! -e /dev/i2c-1 ]]; then
    echo "Creating /dev/i2c-1 (requires sudo)..."
    sudo touch /dev/i2c-1
fi

# Start Home Assistant
uv run hass --config "${PWD}/config" --debug
